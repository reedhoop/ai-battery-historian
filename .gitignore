# Go 构建产物
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
*.prof

# Go 工作区文件
vendor/

# Battery Historian 第三方依赖目录
# closure-library 通过 git submodule 引入，closure-compiler jar 由 setup.go 下载
# 普通用户无需 third_party 即可运行 webui（compiled/ 已入库）
third_party/

# compiled/ 目录包含 webui 运行时必需的 historian-optimized.js（775KB）
# 已入库以便其他机器 clone 后直接 go run，无需 Java/Python/closure-compiler
#compiled/

# Bugreport 测试文件（可能含隐私数据）
bugreport-*.zip
bugreport-*.txt
*.bugreport

# IDE / 编辑器
.idea/
.vscode/
*.swp
*.swo
*~

# 操作系统
.DS_Store
Thumbs.db
desktop.ini

# 临时解压目录
_bugreport_extract/

# AOSP 源码 review 期间的临时样本和调试脚本
_aosp_review/

# 真机 bugreport 样本目录（含隐私数据，不入库）
_samples/

# 临时脚本
_tmp_*.sh
